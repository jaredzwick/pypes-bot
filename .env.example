# pypes-bot configuration
# Copy to .env (or pypes.env when running via npx) and fill in every required value.
# Validated by Zod at startup — missing/malformed values fail-fast with a clear message.

# === Slack ===
# From your Slack app's "Basic Information" page:
SLACK_SIGNING_SECRET=

# From "OAuth & Permissions" — starts with xoxb-:
SLACK_BOT_TOKEN=

# Comma-separated Slack user IDs (U...) allowed to trigger the bot.
# Find your user ID: Slack profile → ••• → "Copy member ID".
PYPES_ALLOWED_USER_IDS=

# Comma-separated channel IDs (C...) the bot listens in.
# Find channel IDs: channel header → "About" → bottom of panel.
PYPES_ALLOWED_CHANNELS=

# === GitHub Actions dispatch ===
# Fine-grained PAT scoped to ONE repo with:
#   - Actions: Read and Write
#   - Contents: Read and Write
#   - Pull requests: Read and Write
# Generate at: https://github.com/settings/personal-access-tokens
PYPES_GH_PAT=

# Format: owner/repo
PYPES_GH_REPO=

# Workflow filename in that repo's .github/workflows/. The template ships
# with the project as docs/pypes-bot-autopilot.yaml — copy it into your repo.
PYPES_GH_WORKFLOW=pypes-bot-autopilot.yaml
PYPES_GH_REF=main

# === Runner callback (cost reporting + budget enforcement) ===
# 32+ char random secret shared with your GH Actions workflow. Generate:
#   openssl rand -hex 32
PYPES_RUNNER_CALLBACK_SECRET=

# Publicly reachable URL of THIS bot (cloudflared tunnel or ngrok).
# The runner POSTs cost reports back here.
PYPES_PUBLIC_URL=

# === Anthropic (intent classifier in the bot itself) ===
# A small Anthropic key — used ONLY for fast 1-turn intent classification.
# The runner uses its OWN ANTHROPIC_API_KEY from GitHub repo secrets.
# Recommend: dedicated key with $5/mo console spend cap.
ANTHROPIC_API_KEY=

# === Tunables (all optional) ===
PYPES_POLL_INTERVAL_SECONDS=15
PYPES_DAILY_BUDGET_USD=50
PYPES_MAX_BUDGET_USD=10
PYPES_MAX_TURNS=15
PYPES_CLAUDE_MODEL=haiku
PYPES_INTENT_MODEL=claude-haiku-4-5-20251001

# === Customization (optional) ===
# If set, the file at this path is loaded as the system prompt sent to the
# runner's Claude. Without this, a generic default is used.
# Typical usage: -v ./my-system-prompt.md:/etc/pypes/system-prompt.md
PYPES_SYSTEM_PROMPT_FILE=

# === Infrastructure ===
DATABASE_PATH=/data/pypes.db
PORT=8080
PYPES_HOSTNAME=pypes-bot
